Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "calculates", " ", "new", " ", "temperature", " ", 
    RowBox[{"profile", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Running", " ", "this", " ", "loop", " ", "can", " ", "take", " ", "a", 
    " ", "couple", " ", "of", " ", 
    RowBox[{"minutes", ".", " ", "You"}], " ", "can", " ", "see", " ", "the", 
    " ", "how", " ", "far", " ", "the", " ", "process", " ", "is", " ", 
    "thanks", " ", "to", " ", "the", " ", "ProgressIndicator"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"\[Epsilon]", ">", "\[Epsilon]conv"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{
           "This", " ", "defines", " ", "the", " ", "new", " ", "temperature",
             " ", "field", " ", "using", " ", "the", " ", "formula", " ", 
            "of", " ", "the", " ", "Picard", " ", 
            RowBox[{"iteration", ".", " ", "ii"}]}], ",", " ", 
           RowBox[{
            RowBox[{"coresponds", " ", "with", " ", "the", " ", "x"}], "-", 
            RowBox[{
             RowBox[{"coordinate", ".", " ", "jj"}], " ", "corresponds", " ", 
             "with", " ", "the", " ", "y"}], "-", 
            RowBox[{
             RowBox[{"coordinate", ".", " ", "kk"}], " ", "corresponds", " ", 
             "with", " ", "the", " ", "z"}], "-", "axis"}]}], " ", "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Tnew", "[", 
             RowBox[{"[", 
              RowBox[{"ii", ",", "jj", ",", "kk"}], "]"}], "]"}], "=", 
            RowBox[{
             FractionBox["1", "6"], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Told", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"ii", "-", "1"}], ",", "jj", ",", "kk"}], "]"}], 
                "]"}], "+", 
               RowBox[{"Told", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"ii", "+", "1"}], ",", "jj", ",", "kk"}], "]"}], 
                "]"}], "+", 
               RowBox[{"Told", "[", 
                RowBox[{"[", 
                 RowBox[{"ii", ",", 
                  RowBox[{"jj", "-", "1"}], ",", "kk"}], "]"}], "]"}], "+", 
               RowBox[{"Told", "[", 
                RowBox[{"[", 
                 RowBox[{"ii", ",", 
                  RowBox[{"jj", "+", "1"}], ",", "kk"}], "]"}], "]"}], "+", 
               RowBox[{"Told", "[", 
                RowBox[{"[", 
                 RowBox[{"ii", ",", "jj", ",", 
                  RowBox[{"kk", "-", "1"}]}], "]"}], "]"}], "+", 
               RowBox[{"Told", "[", 
                RowBox[{"[", 
                 RowBox[{"ii", ",", "jj", ",", 
                  RowBox[{"kk", "+", "1"}]}], "]"}], "]"}]}], ")"}]}]}], 
           ";"}], "\[IndentingNewLine]", ",", 
          RowBox[{"{", 
           RowBox[{"ii", ",", "2", ",", 
            RowBox[{"n", "+", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"jj", ",", "2", ",", 
            RowBox[{"n", "+", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"kk", ",", "2", ",", 
            RowBox[{"n", "+", "1"}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"This", " ", "calculates", " ", "the", " ", "new", " ", 
          RowBox[{"convergence", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"\[Epsilon]", "=", 
         RowBox[{"N", "[", 
          RowBox[{"Total", "[", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"Tnew", "-", "Told"}], "]"}], ",", "3"}], "]"}], "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "This", " ", "replaces", " ", "the", " ", "old", " ", "field", " ", 
          "with", " ", "the", " ", "new", " ", 
          RowBox[{"field", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"Told", "=", "Tnew"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
     ";"}], "\[IndentingNewLine]", ",", 
    RowBox[{"ProgressIndicator", "[", 
     RowBox[{
      RowBox[{"Dynamic", "[", 
       FractionBox["1", "\[Epsilon]"], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", 
        FractionBox["1", "\[Epsilon]conv"]}], "}"}]}], "]"}]}], 
   "]"}]}]], "Input",
