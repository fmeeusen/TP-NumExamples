Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "initializes", " ", "new", " ", 
    RowBox[{"field", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Tnewq", "=", "Toldq"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"According", " ", "to", " ", 
      RowBox[{"Fourier", "'"}], "s", " ", "law"}], ",", 
     RowBox[{
     "we", " ", "need", " ", "to", " ", "have", " ", "a", " ", "value", " ", 
      "for", " ", "the", " ", "thermal", " ", "conductivity", " ", 
      RowBox[{"coefficient", ".", " ", "In"}], " ", "this", " ", "example", 
      " ", "I", " ", "will", " ", "use", " ", "the", " ", "value", " ", "for",
       " ", "copper", " ", 
      RowBox[{"(", 
       RowBox[{"\[Lambda]", "=", 
        RowBox[{"401", " ", 
         RowBox[{"(", 
          RowBox[{"W", "/", 
           RowBox[{"(", 
            RowBox[{"m", "*", "K"}], ")"}]}], ")"}]}]}], ")"}]}]}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Lambda]", "=", "401"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "We", " ", "use", " ", "the", " ", "same", " ", "value", " ", "for", " ", 
     "the", " ", "convergion", " ", "parameter", " ", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Epsilon]", "q"], " ", "=", " ", 
       RowBox[{"\[Epsilon]", " ", "=", " ", "1"}]}], ")"}], " ", "and", " ", 
     "convergion", " ", "cirteria", " ", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Epsilon]conv", "q"], " ", "=", " ", 
       RowBox[{"\[Epsilon]conv", " ", "=", " ", 
        SuperscriptBox["10", 
         RowBox[{"-", "2"}]]}]}], ")"}], " ", "as", " ", "above"}], " ", 
    "*)"}]}]}]], "Input",
