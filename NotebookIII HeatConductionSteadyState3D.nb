Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "initializes", " ", "convergence", " ", 
    RowBox[{"parameter", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[Epsilon]", "q"], "=", "1"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"This", " ", "sets", " ", "the", " ", "convergence", " ", 
     RowBox[{"criterion", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     SubscriptBox["\[Epsilon]conv", "q"], "=", "0.01"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.8577867965679636`*^9, 3.8577868602312374`*^9}, {
  3.8604810871041927`*^9, 3.8604811229562435`*^9}, {3.8608195313971043`*^9, 
  3.8608196061860065`*^9}, {3.8608202900003123`*^9, 3.860820294507659*^9}},
