Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "calculates", " ", "new", " ", "temperature", " ", 
    RowBox[{"profile", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[Epsilon]", "q"], ">", 
        SubscriptBox["\[Epsilon]conv", "q"]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Tnewq", "[", 
             RowBox[{"[", 
              RowBox[{"ii", ",", "jj", ",", "kk"}], "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "/", "6"}], ")"}], 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Toldq", "[", 
                 RowBox[{"[", 
                  RowBox[{
                   RowBox[{"ii", "-", "1"}], ",", "jj", ",", "kk"}], "]"}], 
                 "]"}], "+", 
                RowBox[{"Toldq", "[", 
                 RowBox[{"[", 
                  RowBox[{
                   RowBox[{"ii", "+", "1"}], ",", "jj", ",", "kk"}], "]"}], 
                 "]"}], "+", 
                RowBox[{"Toldq", "[", 
                 RowBox[{"[", 
                  RowBox[{"ii", ",", 
                   RowBox[{"jj", "-", "1"}], ",", "kk"}], "]"}], "]"}], "+", 
                RowBox[{"Toldq", "[", 
                 RowBox[{"[", 
                  RowBox[{"ii", ",", 
                   RowBox[{"jj", "+", "1"}], ",", "kk"}], "]"}], "]"}], "+", 
                RowBox[{"Toldq", "[", 
                 RowBox[{"[", 
                  RowBox[{"ii", ",", "jj", ",", 
                   RowBox[{"kk", "-", "1"}]}], "]"}], "]"}], "+", 
                RowBox[{"Toldq", "[", 
                 RowBox[{"[", 
                  RowBox[{"ii", ",", "jj", ",", 
                   RowBox[{"kk", "+", "1"}]}], "]"}], "]"}]}], ")"}]}], "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "/", 
                RowBox[{"(", 
                 RowBox[{"6", "*", "\[Lambda]"}], ")"}]}], ")"}], "*", 
              RowBox[{"q", "[", 
               RowBox[{"[", 
                RowBox[{"ii", ",", "jj", ",", "kk"}], "]"}], "]"}]}]}]}], 
           ";"}], "\[IndentingNewLine]", ",", 
          RowBox[{"{", 
           RowBox[{"ii", ",", "2", ",", 
            RowBox[{"n", "+", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"jj", ",", "2", ",", 
            RowBox[{"n", "+", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"kk", ",", "2", ",", 
            RowBox[{"n", "+", "1"}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"This", " ", "calculates", " ", "the", " ", "new", " ", 
          RowBox[{"convergence", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         SubscriptBox["\[Epsilon]", "q"], "=", 
         RowBox[{"N", "[", 
          RowBox[{"Total", "[", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"Tnewq", "-", "Toldq"}], "]"}], ",", "3"}], "]"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "This", " ", "replaces", " ", "the", " ", "old", " ", "field", " ", 
          "with", " ", "the", " ", "new", " ", 
          RowBox[{"field", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"Toldq", "=", "Tnewq"}], ";"}]}], "\[IndentingNewLine]", 
      "]"}], ";"}], "\[IndentingNewLine]", ",", 
    RowBox[{"ProgressIndicator", "[", 
     RowBox[{
      RowBox[{"Dynamic", "[", 
       RowBox[{"1", "/", 
        SubscriptBox["\[Epsilon]", "q"]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", 
        RowBox[{"1", "/", 
         SubscriptBox["\[Epsilon]conv", "q"]}]}], "}"}]}], "]"}]}], 
   "]"}]}]], "Input",
