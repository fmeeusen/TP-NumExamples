Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "calculates", " ", "new", " ", "temperature", " ", 
    RowBox[{"profile", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"TnewLoop", "=", 
    RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "First", " ", "check", " ", "if", " ", "the", " ", "Fourier", " ", 
       "number", " ", "is", " ", "still", " ", "smaller", " ", "than", " ", 
       "0.1"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"While", "[", 
        RowBox[{
         RowBox[{"Tmax", ">", "t"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Do", "[", "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{
            "The", " ", "formula", " ", "for", " ", "the", " ", "Picard", " ",
              "iteration", " ", "is", " ", "given", " ", "in", " ", "the", 
             " ", "book", " ", 
             RowBox[{"(", 
              RowBox[{"see", " ", "3.3", ".8"}], ")"}]}], " ", "*)"}], 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"Tnew", "[", 
              RowBox[{"[", "ii", "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "-", 
                 FractionBox[
                  RowBox[{"2", "a", "*", "\[CapitalDelta]t"}], 
                  SuperscriptBox["\[CapitalDelta]x", "2"]]}], ")"}], 
               RowBox[{"Told", "[", 
                RowBox[{"[", "ii", "]"}], "]"}]}], "+", 
              RowBox[{
               FractionBox[
                RowBox[{"a", "*", "\[CapitalDelta]t"}], 
                SuperscriptBox["\[CapitalDelta]x", "2"]], 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Told", "[", 
                  RowBox[{"[", 
                   RowBox[{"ii", "-", "1"}], "]"}], "]"}], "+", 
                 RowBox[{"Told", "[", 
                  RowBox[{"[", 
                   RowBox[{"ii", "+", "1"}], "]"}], "]"}]}], ")"}]}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"ii", ",", " ", "2", ",", " ", 
              RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", " ", 
           RowBox[{
           "This", " ", "calculates", " ", "the", " ", "new", " ", "value", 
            " ", "for", " ", 
            RowBox[{"time", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"t", "=", 
           RowBox[{"t", "+", "\[CapitalDelta]t"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", " ", 
           RowBox[{
           "This", " ", "replaces", " ", "the", " ", "old", " ", "profile", 
            " ", "with", " ", "the", " ", "new", " ", 
            RowBox[{"profile", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"Told", "=", "Tnew"}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "The", " ", "new", " ", "temperature", " ", "profile", " ", "is", 
            " ", "added", " ", "to", " ", "the", " ", "list", " ", "so", " ", 
            "that", " ", "we", " ", "can", " ", "later", " ", "on", " ", 
            "find", " ", "the", " ", "temperature", " ", "profile", " ", "at",
             " ", "each", " ", "time", " ", "interval"}], " ", "*)"}], 
          "\[IndentingNewLine]", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"TnewList", ",", " ", "Tnew"}], "]"}], ";"}]}], 
        "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", ",", 
      RowBox[{"ProgressIndicator", "[", 
       RowBox[{
        RowBox[{"Dynamic", "[", 
         FractionBox["1", "Tmax"], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          FractionBox["1", "\[CapitalDelta]t"]}], "}"}]}], "]"}]}], "]"}]}], 
   ";"}]}]], "Input",
