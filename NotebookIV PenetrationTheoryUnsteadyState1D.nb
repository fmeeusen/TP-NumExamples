Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "initalizes", " ", "the", " ", "new", " ", "Temperature", " ", 
    RowBox[{"profile", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Tnew", "=", "Told"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "initializes", " ", "the", " ", "new", " ", "Temperature", 
     " ", "profile", " ", "in", " ", "the", " ", "form", " ", "of", " ", "a", 
     " ", 
     RowBox[{"list", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
