Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
    "In", " ", "this", " ", "notebook", " ", "we", " ", "will", " ", "create",
      " ", "a", " ", "numerical", " ", "solution", " ", "for", " ", "an", " ",
      "unsteadystate", " ", "heat", " ", "conduction", " ", "problem", " ", 
     "in", " ", "a", " ", "slab", " ", "using", " ", "Penetration", " ", 
     RowBox[{"theory", ".", " ", "The"}], " ", "objective", " ", "is", " ", 
     "to", " ", "find", " ", "the", " ", "temperature", " ", "profile", " ", 
     "at", " ", "each", " ", "time", " ", 
     RowBox[{"interval", ".", " ", "Consider"}], " ", "a", " ", "copper", " ",
      "slab", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", " ", "=", " ", 
        RowBox[{
         RowBox[{"1.17", "*", 
          SuperscriptBox["10", 
           RowBox[{"-", "4"}]], " ", 
          RowBox[{
           SuperscriptBox["m", "2"], "/", "s"}], " ", "and", " ", "D"}], " ", 
         "=", " ", 
         RowBox[{"1", "m"}]}]}], ")"}], ".", " ", "At"}], " ", "t"}], "=", 
    RowBox[{
    "0", " ", "the", " ", "temperature", " ", "on", " ", "the", " ", "left", 
     " ", "side", " ", 
     RowBox[{"(", 
      RowBox[{"x", "=", "0"}], ")"}], " ", "is", " ", "raised", " ", "to", 
     " ", "50", "\[Degree]C"}]}], ",", " ", 
   RowBox[{
   "while", " ", "the", " ", "rest", " ", "of", " ", "the", " ", "object", 
    " ", "is", " ", "0", 
    RowBox[{"\[Degree]C", ".", " ", "For"}], " ", "numerical", " ", 
    "solutions"}], ",", " ", 
   RowBox[{"the", " ", "domain", " ", "must", " ", "be", " ", "finite"}], ",",
    " ", 
   RowBox[{
    RowBox[{
    "therefore", " ", "we", " ", "are", " ", "going", " ", "to", " ", 
     "define", " ", "the", " ", "slab", " ", "as", " ", "a", " ", "array", 
     " ", "of", " ", "20", " ", "cells", " ", "with", " ", "a", " ", "width", 
     " ", "of", " ", "\[EmptyUpTriangle]x"}], " ", "=", " ", 
    RowBox[{"0.02", " ", 
     RowBox[{"m", ".", " ", "Furthermore"}]}]}], ",", " ", 
   RowBox[{
    RowBox[{
    "the", " ", "continous", " ", "increase", " ", "of", " ", "time", " ", 
     "is", " ", "discrezitised", " ", "as", " ", "well", " ", "into", " ", 
     "intervals", " ", "of", " ", "\[EmptyUpTriangle]t"}], " ", "=", " ", 
    RowBox[{
     RowBox[{
     "0.85", " ", "s", " ", "The", " ", "boundary", " ", "conditions", " ", 
      "are", " ", "T", 
      RowBox[{"(", 
       RowBox[{"0", ",", "t"}], ")"}]}], "=", 
     RowBox[{
      RowBox[{"50", " ", "and", " ", "T", 
       RowBox[{"(", 
        RowBox[{"20", ",", "t"}], ")"}]}], "=", " ", 
      RowBox[{
       RowBox[{"0", " ", "for", " ", "every", " ", 
        RowBox[{"t", ".", " ", "The"}], " ", "penetration", " ", "theory", 
        " ", "can", " ", "only", " ", "be", " ", "used", " ", "if", " ", 
        "the", " ", "Fourier", " ", "number", " ", "is", " ", "smaller", " ", 
        "than", " ", "0.1", " ", "Which", " ", "corresponds", " ", "to", " ", 
        SqrtBox["\[Pi]at"]}], "<", " ", 
       RowBox[{"0.6", "D"}]}]}]}]}], ",", " ", 
   RowBox[{
   "where", " ", "we", " ", "use", " ", "the", " ", "thermal", " ", 
    "diffusivity", " ", "of", " ", "copper", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"a", "=", 
       RowBox[{
        FractionBox["\[Lambda]", 
         SubscriptBox["\[Rho]c", "p"]], "=", 
        RowBox[{"1.17", 
         SuperscriptBox["x10", 
          RowBox[{"-", "4"}]], " ", 
         RowBox[{
          SuperscriptBox["m", "2"], "/", "s"}]}]}]}], ")"}], ".", " ", 
     "Solving"}], " ", "this", " ", "for", " ", "t", " ", "gives", " ", 
    RowBox[{"us", ":", " ", 
     RowBox[{"t", " ", "<", " ", 
      RowBox[{"980", 
       RowBox[{"s", ".", " ", "Which"}], " ", "will", " ", "be", " ", "the", 
       " ", "condition", " ", "for", " ", "our", " ", "while", " ", 
       "loop"}]}]}]}]}], "*)"}]], "Input",
