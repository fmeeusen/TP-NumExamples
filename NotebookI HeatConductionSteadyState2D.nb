Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "initializes", " ", "convergence", " ", 
    RowBox[{"parameter", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Epsilon]", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"This", " ", "sets", " ", "the", " ", "convergence", " ", 
     RowBox[{"criterion", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]conv", "=", 
     SuperscriptBox["10", 
      RowBox[{"-", "3"}]]}], ";"}]}]}]], "Input",
 CellLabel->"In[33]:=",ExpressionUUID->"16265ff2-1590-41a1-925e-5ec951022091"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "calculates", " ", "new", " ", "temperature", " ", 
    RowBox[{"profile", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"\[Epsilon]", ">", "\[Epsilon]conv"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{
          "The", " ", "formula", " ", "of", " ", "the", " ", "Picard", " ", 
           "iteration", " ", "now", " ", "also", " ", "contains", " ", "a", 
           " ", "heat", " ", "production", " ", "term"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Tnewq", "[", 
             RowBox[{"[", 
              RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{
              FractionBox["1", "4"], 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Toldq", "[", 
                 RowBox[{"[", 
                  RowBox[{
                   RowBox[{"ii", "-", "1"}], ",", "jj"}], "]"}], "]"}], "+", 
                RowBox[{"Toldq", "[", 
                 RowBox[{"[", 
                  RowBox[{
                   RowBox[{"ii", "+", "1"}], ",", "jj"}], "]"}], "]"}], "+", 
                RowBox[{"Toldq", "[", 
                 RowBox[{"[", 
                  RowBox[{"ii", ",", 
                   RowBox[{"jj", "-", "1"}]}], "]"}], "]"}], "+", 
                RowBox[{"Toldq", "[", 
                 RowBox[{"[", 
                  RowBox[{"ii", ",", 
                   RowBox[{"jj", "+", "1"}]}], "]"}], "]"}]}], ")"}]}], "+", 
             RowBox[{
              FractionBox["1", 
               RowBox[{"4", "*", "\[Lambda]"}]], "*", 
              RowBox[{"q", "[", 
               RowBox[{"[", 
                RowBox[{"ii", ",", "jj"}], "]"}], "]"}]}]}]}], ";"}], 
          "\[IndentingNewLine]", ",", 
          RowBox[{"{", 
           RowBox[{"ii", ",", "2", ",", 
            RowBox[{"n", "+", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
