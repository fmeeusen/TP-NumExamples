Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"According", " ", "to", " ", 
     RowBox[{"Fourier", "'"}], "s", " ", "law"}], ",", 
    RowBox[{
    "we", " ", "need", " ", "to", " ", "have", " ", "a", " ", "value", " ", 
     "for", " ", "the", " ", "thermal", " ", "conductivity", " ", 
     RowBox[{"coefficient", ".", " ", "In"}], " ", "this", " ", "example", 
     " ", "I", " ", "will", " ", "use", " ", "the", " ", "value", " ", "for", 
     " ", "copper", " ", 
     RowBox[{"(", 
      RowBox[{"\[Lambda]", "=", 
       RowBox[{"401", " ", 
        FractionBox["W", 
         RowBox[{"m", "*", "K"}]]}]}], ")"}]}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"\[Lambda]", "=", "401"}], ";"}]}]], "Input",
