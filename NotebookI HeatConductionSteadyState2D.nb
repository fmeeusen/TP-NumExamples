Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "calculates", " ", "new", " ", "temperature", " ", 
    RowBox[{"profile", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"\[Epsilon]", ">", "\[Epsilon]conv"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Here", " ", 
            RowBox[{"Tnew", "[", 
             RowBox[{"[", 
              RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "corresponds", " ", 
            "to", " ", "Tp", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
              "as", " ", "it", " ", "is", " ", "called", " ", "in", " ", 
               "the", " ", "paper"}], ")"}], ".", " ", "\[IndentingNewLine]", 
             RowBox[{"Told", "[", 
              RowBox[{"[", 
               RowBox[{
                RowBox[{"ii", "-", "1"}], ",", "jj"}], "]"}], "]"}]}], " ", 
            "corresponds", " ", "with", " ", "Tw"}], ",", " ", 
           "\[IndentingNewLine]", "  ", 
           RowBox[{
            RowBox[{"Told", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"ii", "+", "1"}], ",", "jj"}], "]"}], "]"}], " ", 
            "corresponds", " ", "with", " ", "Te"}], ",", " ", 
           "\[IndentingNewLine]", "  ", 
           RowBox[{
            RowBox[{"Told", "[", 
             RowBox[{"[", 
              RowBox[{"ii", ",", 
               RowBox[{"jj", "-", "1"}]}], "]"}], "]"}], " ", "corresponds", 
            " ", "with", " ", "Tn", " ", "\[IndentingNewLine]", " ", "and", 
            " ", 
            RowBox[{"Told", "[", 
             RowBox[{"[", 
              RowBox[{"ii", ",", 
               RowBox[{"jj", "+", "1"}]}], "]"}], "]"}], " ", "corresponds", 
            " ", "with", " ", "Ts"}]}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "Tp", " ", "is", " ", "calculated", " ", "using", " ", "the", " ", 
           "formula", " ", "of", " ", "the", " ", "Picard", " ", 
           "iteration"}], " ", "*)"}], "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Tnew", "[", 
             RowBox[{"[", 
              RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "=", 
            RowBox[{
             FractionBox["1", "4"], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Told", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"ii", "-", "1"}], ",", "jj"}], "]"}], "]"}], "+", 
               RowBox[{"Told", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"ii", "+", "1"}], ",", "jj"}], "]"}], "]"}], "+", 
               RowBox[{"Told", "[", 
                RowBox[{"[", 
                 RowBox[{"ii", ",", 
                  RowBox[{"jj", "-", "1"}]}], "]"}], "]"}], "+", 
               RowBox[{"Told", "[", 
                RowBox[{"[", 
                 RowBox[{"ii", ",", 
                  RowBox[{"jj", "+", "1"}]}], "]"}], "]"}]}], ")"}]}]}], 
           ";"}], "\[IndentingNewLine]", ",", 
          RowBox[{"{", 
           RowBox[{"ii", ",", "2", ",", 
            RowBox[{"n", "+", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"jj", ",", "2", ",", 
            RowBox[{"n", "+", "1"}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"This", " ", "calculates", " ", "the", " ", "new", " ", 
          RowBox[{"convergence", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"\[Epsilon]", "=", 
         RowBox[{"Total", "[", 
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{"Tnew", "-", "Told"}], "]"}], ",", "2"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "This", " ", "replaces", " ", "the", " ", "old", " ", "field", " ", 
          "with", " ", "the", " ", "new", " ", 
          RowBox[{"field", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"Told", "=", "Tnew"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
     ";"}], "\[IndentingNewLine]", ",", 
    RowBox[{"ProgressIndicator", "[", 
     RowBox[{
      RowBox[{"Dynamic", "[", 
       FractionBox["1", "\[Epsilon]"], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", 
        FractionBox["1", "\[Epsilon]conv"]}], "}"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.8577868784866037`*^9, 3.857787003357831*^9}, {
   3.857787039299037*^9, 3.8577870870125294`*^9}, {3.8577871189748635`*^9, 
   3.8577872806766305`*^9}, {3.857787386634186*^9, 3.857787386706311*^9}, {
   3.8577878188880715`*^9, 3.8577878506402807`*^9}, {3.8577880439424353`*^9, 
