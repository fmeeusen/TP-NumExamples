Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "initializes", " ", "convergence", " ", 
    RowBox[{"parameter", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Epsilon]", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"This", " ", "sets", " ", "the", " ", "convergence", " ", 
     RowBox[{"criterion", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]conv", "=", 
     SuperscriptBox["10", 
      RowBox[{"-", "3"}]]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.8577867965679636`*^9, 3.8577868602312374`*^9}, {
  3.8604810871041927`*^9, 3.8604811229562435`*^9}},
