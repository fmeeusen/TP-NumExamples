Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "initializes", " ", "convergence", " ", 
    RowBox[{"parameter", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Epsilon]", "=", "10"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"This", " ", "sets", " ", "the", " ", "convergence", " ", 
     RowBox[{"criterion", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Since", " ", "the", " ", "dimensions", " ", "of", " ", "the", " ", 
      "field", " ", "is", " ", "rather", " ", "large"}], ",", " ", 
     RowBox[{
     "the", " ", "value", " ", "of", " ", "the", " ", "criterion", " ", "is", 
      " ", "increased", " ", "to", " ", "reduce", " ", "computation", " ", 
      RowBox[{"time", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]conv", "=", "5"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.8577867965679636`*^9, 3.8577868602312374`*^9}, {
  3.8588259106318426`*^9, 3.858825913256339*^9}, {3.861435650582717*^9, 
  3.861435699001981*^9}},ExpressionUUID->"ec9fda1b-40ae-4111-8e5e-\
4891cd7f2728"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "calculates", " ", "new", " ", "temperature", " ", 
    RowBox[{"profile", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"\[Epsilon]", ">", "\[Epsilon]conv"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"mask", "[", 
               RowBox[{"[", 
                RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "\[Equal]", "1"}], 
             ",", 
             RowBox[{
              RowBox[{"Tnew", "[", 
               RowBox[{"[", 
                RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "=", 
              RowBox[{
               FractionBox["1", "4"], 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Told", "[", 
                  RowBox[{"[", 
                   RowBox[{
                    RowBox[{"ii", "-", "1"}], ",", "jj"}], "]"}], "]"}], "+", 
                 RowBox[{"Told", "[", 
                  RowBox[{"[", 
                   RowBox[{
                    RowBox[{"ii", "+", "1"}], ",", "jj"}], "]"}], "]"}], "+", 
                 RowBox[{"Told", "[", 
                  RowBox[{"[", 
                   RowBox[{"ii", ",", 
                    RowBox[{"jj", "-", "1"}]}], "]"}], "]"}], "+", 
                 RowBox[{"Told", "[", 
                  RowBox[{"[", 
                   RowBox[{"ii", ",", 
                    RowBox[{"jj", "+", "1"}]}], "]"}], "]"}]}], ")"}]}]}]}], 
            "]"}], ";"}], "\[IndentingNewLine]", ",", 
          RowBox[{"{", 
           RowBox[{"ii", ",", "2", ",", 
            RowBox[{"n", "-", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"jj", ",", "2", ",", 
            RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"This", " ", "calculates", " ", "the", " ", "new", " ", 
          RowBox[{"convergence", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"\[Epsilon]", "=", 
         RowBox[{"N", "[", 
          RowBox[{"Total", "[", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"Tnew", "-", "Told"}], "]"}], ",", "2"}], "]"}], "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "This", " ", "replaces", " ", "the", " ", "old", " ", "field", " ", 
          "with", " ", "the", " ", "new", " ", 
          RowBox[{"field", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"Told", "=", "Tnew"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
     ";"}], "\[IndentingNewLine]", ",", 
    RowBox[{"ProgressIndicator", "[", 
     RowBox[{
      RowBox[{"Dynamic", "[", 
       FractionBox["1", "\[Epsilon]"], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", 
        FractionBox["1", "\[Epsilon]conv"]}], "}"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.8577868784866037`*^9, 3.857787003357831*^9}, {
