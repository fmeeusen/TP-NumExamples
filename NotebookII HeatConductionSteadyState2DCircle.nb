Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
     "This", " ", "defines", " ", "a", " ", "grid", " ", "with", " ", "x"}], 
     "-", 
     RowBox[{"coordinates", " ", 
      RowBox[{"(", 
       RowBox[{"using", " ", "spherical", " ", "coordinates"}], ")"}]}]}], 
    ":"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"xgrid", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"x", "-", 
        FractionBox[
         RowBox[{"n", "+", "1"}], "2"]}], ",", 
       RowBox[{"{", "n", "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
      "This", " ", "defines", " ", "a", " ", "grid", " ", "with", " ", "y"}], 
      "-", 
      RowBox[{"coordinates", " ", 
       RowBox[{"(", 
        RowBox[{"using", " ", "spherical", " ", "coordinates"}], ")"}]}]}], 
     ":"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ygrid", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"y", "-", 
        FractionBox[
         RowBox[{"n", "+", "1"}], "2"]}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "1", ",", "n"}], "}"}], ",", 
       RowBox[{"{", "n", "}"}]}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.858824925219152*^9, 3.8588250354353523`*^9}, {
  3.861435475543186*^9, 3.8614354955225573`*^9}, {3.861435530547242*^9, 
  3.861435531122346*^9}},ExpressionUUID->"e286dd41-5f6e-4744-a65a-\
8a53f6d6cdd8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "defines", " ", "a", " ", "circle", " ", "with", " ", "the", 
    " ", "center", " ", "in", " ", "the", " ", "middle", " ", "of", " ", 
    "the", " ", "grid", " ", "and", " ", "maximum", " ", 
    RowBox[{"radius", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "will", " ", "be", " ", "our", " ", "outer", " ", "circle"}], 
   " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"r", "=", 
     SqrtBox[
      RowBox[{
       SuperscriptBox["xgrid", "2"], "+", 
       SuperscriptBox["ygrid", "2"]}]]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"outercircle", "=", 
     RowBox[{
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "\[GreaterEqual]", " ", 
          FractionBox[
           RowBox[{"n", "-", "1"}], "2"]}], "&"}], ",", "r", ",", 
        RowBox[{"{", "2", "}"}]}], "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"True", "\[Rule]", "1"}], ",", 
        RowBox[{"False", "\[Rule]", "0"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "defines", " ", "a", " ", "circle", " ", "with", " ", "the", 
     " ", "center", " ", "NOT", " ", "in", " ", "the", " ", "middle", " ", 
     "of", " ", "the", " ", "grid", " ", "with", " ", "a", " ", "small", " ", 
     RowBox[{"radius", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "will", " ", "be", " ", "our", " ", "inner", " ", "cirlce"}],
     " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"r", "=", 
     SqrtBox[
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"xgrid", "-", "3"}], ")"}], "2"], "+", 
       SuperscriptBox["ygrid", "2"]}]]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"innercircle", "=", 
     RowBox[{
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "<", "3"}], "&"}], ",", "r", ",", 
        RowBox[{"{", "2", "}"}]}], "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"True", "\[Rule]", "1"}], ",", 
        RowBox[{"False", "\[Rule]", "0"}]}], "}"}]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.858825039237714*^9, 3.858825406331541*^9}, {
  3.858825967174983*^9, 3.858826003682905*^9}, {3.861435550380045*^9, 
  3.861435615145872*^9}},ExpressionUUID->"857bda3a-63a3-4141-b14a-\
7a41c21bf877"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "defines", " ", "a", " ", 
    RowBox[{"mask", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"mask", "=", 
     RowBox[{"1", "-", 
      RowBox[{"(", 
       RowBox[{"outercircle", "+", "innercircle"}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"TableForm", "[", "mask", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "defines", " ", "the", " ", "temperature", " ", "of", " ", 
     "the", " ", 
     RowBox[{"innercircle", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"innercircle", "*=", "50"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "defines", " ", "the", " ", "temperature", " ", "of", " ", 
     "the", " ", 
     RowBox[{"outercircle", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"outercircle", "*=", "10"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.858825408799712*^9, 3.8588255327242923`*^9}, {
   3.8611912878787193`*^9, 3.8611913059409604`*^9}, 3.8611913547623887`*^9},
 CellLabel->"In[83]:=",ExpressionUUID->"29560acb-cb84-4311-a44c-26f80b196400"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "defines", " ", "the", " ", "initial", " ", "temperature", 
    " ", 
    RowBox[{"map", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Told", "=", 
