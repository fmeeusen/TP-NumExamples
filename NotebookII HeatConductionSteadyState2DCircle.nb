    "internal", " ", 
    RowBox[{"celss", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"n", "=", "50"}], ";"}]}]], "Input",
 CellChangeTimes->{{3.857786507842226*^9, 3.8577865184483204`*^9}, {
